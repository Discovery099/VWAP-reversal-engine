//@version=6
strategy("Post-Absorption VWAP Reversal Engine V10 (Research Build)", overlay=true, pyramiding=0, process_orders_on_close=false, calc_on_every_tick=false, commission_type=strategy.commission.cash_per_contract, commission_value=0)

// ─────────────────────────────────────────────────────────────────────────────
// V10 RESEARCH BUILD — TESTABLE ENHANCEMENTS ON TOP OF V9.1 BASELINE
//
// This script preserves all V9.1 logic and adds 7 toggleable enhancements
// for isolated A/B testing in TradingView backtests. Default settings have
// ALL enhancements OFF so V10 reproduces V9.1 baseline behavior exactly.
//
// ENHANCEMENTS (all default OFF):
//   A) Higher-timeframe trend filter (HTF)
//   B) Volatility regime filter (ATR percentile)
//   C) Time-decay exit (progressive stop tightening)
//   D) Trailing stop on favorable excursion
//   E) Multi-contract partial exit (requires qty ≥2)
//   F) Signal-quality score filter
//   G) Dashboard score display
//
// To validate baseline match: Run V10 with all enhancements OFF → should
// produce identical results to V9.1 with same inputs.
//
// To test enhancements: Enable one enhancement at a time, backtest, compare
// to V10 baseline. Document which ones improve PF/expectancy/DD.
// ─────────────────────────────────────────────────────────────────────────────

// ── Input groups ─────────────────────────────────────────────────────────────
groupGeneral      = "01 General"
groupExec         = "02 Execution Mode"
groupPresets      = "03 Strategy Presets"
groupAbsorb       = "04 Absorption Detection"
groupTrade        = "05 Trading Behavior"
groupSession      = "06 Session Filter"
groupRisk2        = "07 Risk Gates (opt-in)"
groupExit         = "08 Exit / EOD"
groupAlerts       = "09 Webhook Alerts"
groupVisuals      = "10 Visuals / Debug"
groupEnhanceHTF   = "11 Enhancement A: HTF Trend Filter"
groupEnhanceVol   = "12 Enhancement B: Volatility Regime"
groupEnhanceDecay = "13 Enhancement C: Time-Decay Exit"
groupEnhanceTrail = "14 Enhancement D: Trailing Stop"
groupEnhancePartial = "15 Enhancement E: Partial Exit"
groupEnhanceScore = "16 Enhancement F: Signal Quality Score"

// ── General ──────────────────────────────────────────────────────────────────
enableAbsorptionModule = input.bool(true,  "Enable absorption module", group=groupGeneral)
useRthOnly             = input.bool(true,  "Use RTH only", group=groupGeneral)
rthSession             = input.session("0930-1600", "RTH session", group=groupGeneral)
rthTimezone            = input.string("America/New_York", "RTH timezone", group=groupGeneral)

// ── Execution mode (gate for live) ───────────────────────────────────────────
executionMode = input.string("Sim/Paper", "Execution mode  (Live requires webhookMode='live' too)", options=["Backtest only", "Sim/Paper", "Live"], group=groupExec)
enablePaperStrategy = input.bool(true, "Place strategy orders (must be ON for any alert to fire)", group=groupExec)

// ── Presets ──────────────────────────────────────────────────────────────────
presetMode = input.string("ES V9 Balanced", "Active preset", options=["ES V9 Balanced", "ES Paper Candidate", "Manual", "Default setup", "Candidate 1: VL75 / VP97.5 / ATR60 / Disp0.5 / Near0.5 / H20", "Candidate 4: VL100 / VP97.5 / ATR60 / Disp0.2 / Near0.1 / H10", "Candidate 8: VL100 / VP97.5 / ATR20 / Disp0.3 / Near0.25 / H5"], group=groupPresets)

manualVolumeLookback                = input.int(100, "Manual volume lookback", minval=5, group=groupAbsorb)
manualHighVolumePercentileThreshold = input.float(95.0, "Manual high volume percentile", minval=50, maxval=100, step=0.5, group=groupAbsorb)
manualAtrLength                     = input.int(60, "Manual ATR length", minval=1, group=groupAbsorb)
manualMaxDisplacementAtr            = input.float(0.30, "Manual max displacement / ATR", minval=0.0, step=0.05, group=groupAbsorb)
manualNearVwapThresholdAtr          = input.float(0.25, "Manual near VWAP threshold / ATR", minval=0.0, step=0.05, group=groupAbsorb)
manualReversalHorizonBars           = input.int(15, "Manual horizon bars", minval=1, group=groupAbsorb)

// ── Trading ──────────────────────────────────────────────────────────────────
allowFadeAboveVwap  = input.bool(true,  "Allow above-VWAP short fades", group=groupTrade)
allowFadeBelowVwap  = input.bool(true,  "Allow below-VWAP long fades", group=groupTrade)
paperDirectionMode  = input.string("Both", "Direction mode", options=["Both", "Longs only", "Shorts only"], group=groupTrade)
exitMode            = input.string("VWAP target + ATR stop + time stop", "Exit mode", options=["VWAP target + ATR stop + time stop", "Fixed horizon only", "VWAP target only", "ATR stop only"], group=groupTrade)
nextBarEntryOnly    = input.bool(true,  "Next-bar entry only", group=groupTrade)
allowSameBarExit    = input.bool(false, "Allow same-bar exit", group=groupTrade)
pendingEntryMaxBars = input.int(1, "Pending entry max bars", minval=1, maxval=5, group=groupTrade)
stopAtrMultiple     = input.float(1.0, "Stop ATR multiple beyond signal bar", minval=0.1, step=0.1, group=groupTrade)
maxTradesPerDay     = input.int(3, "Max trades per day", minval=0, maxval=20, group=groupTrade)

// ── Session ──────────────────────────────────────────────────────────────────
useSessionFilter   = input.bool(true,  "Use session filter", group=groupSession)
blockHour11        = input.bool(true,  "Block 11am NY hour", group=groupSession)
blockMidday        = input.bool(true,  "Block midday window  (V9.1 default ON — recent data supports 10-13 block)", group=groupSession)
middayStartHour    = input.int(10, "Midday block start hour NY", minval=0, maxval=23, group=groupSession)
middayStartMin     = input.int(0,  "Midday block start minute NY", minval=0, maxval=59, group=groupSession)
middayEndHour      = input.int(13, "Midday block end hour NY", minval=0, maxval=23, group=groupSession)
middayEndMin       = input.int(0,  "Midday block end minute NY", minval=0, maxval=59, group=groupSession)
allowedDays        = input.string("Mon-Fri", "Allowed days", options=["Mon-Fri", "Mon-Thu", "Tue-Thu"], group=groupSession)
blockLongsHour12   = input.bool(false, "Block longs during 12pm NY hour (opt-in)", group=groupSession)
blockShortsHour14  = input.bool(false, "Block shorts during 2pm NY hour (opt-in)", group=groupSession)
blockFridayShorts  = input.bool(false, "Block Friday shorts (opt-in)", group=groupSession)
useEntryCutoff     = input.bool(false, "Stop new entries before close (opt-in)", group=groupSession)
entryCutoffHour    = input.int(15, "Last new-entry hour NY", minval=0, maxval=23, group=groupSession)
entryCutoffMin     = input.int(50, "Last new-entry minute NY", minval=0, maxval=59, group=groupSession)

// ── Risk gates (opt-in) ──────────────────────────────────────────────────────
useDailyLossStop      = input.bool(false, "Daily loss stop", group=groupRisk2)
dailyLossStopDollar   = input.float(800.0, "Daily loss stop $", minval=0.0, step=25.0, group=groupRisk2)
useDailyProfitLock    = input.bool(false, "Daily profit lock", group=groupRisk2)
dailyProfitLockDollar = input.float(800.0, "Daily profit lock $", minval=0.0, step=25.0, group=groupRisk2)
useConsecLossKill     = input.bool(false, "Consecutive-loss halt", group=groupRisk2)
consecLossLimit       = input.int(2, "Consecutive loss limit", minval=1, maxval=10, group=groupRisk2)
useHardDollarStop     = input.bool(false, "Per-trade hard $ stop", group=groupRisk2)
hardDollarStopAmount  = input.float(750.0, "Per-trade hard $ stop $", minval=50.0, step=25.0, group=groupRisk2)
useAccountLossKill    = input.bool(false, "Account loss kill switch (LIVE — persistent halt)", group=groupRisk2)
maxAccountLossDollar  = input.float(1500.0, "Max total strategy loss $", minval=0.0, step=50.0, group=groupRisk2)
usePeakDdKill         = input.bool(false, "Peak drawdown kill switch (LIVE — persistent halt)", group=groupRisk2)
maxPeakDrawdownDollar = input.float(2500.0, "Max drawdown from peak $", minval=0.0, step=50.0, group=groupRisk2)
forceCloseOnHardRisk  = input.bool(true,  "Force close on hard risk halt", group=groupRisk2)
useCushionLock        = input.bool(false, "Lock entries until equity cushion reached", group=groupRisk2)
cushionLockTarget     = input.float(0.0,  "Cushion target $", group=groupRisk2)

// ── EOD ──────────────────────────────────────────────────────────────────────
useEodFlatten     = input.bool(true,  "EOD flatten", group=groupExit)
eodFlattenHour    = input.int(15, "EOD flatten hour NY", minval=0, maxval=23, group=groupExit)
eodFlattenMinute  = input.int(55, "EOD flatten minute NY", minval=0, maxval=59, group=groupExit)

// ── Webhook / alerts ─────────────────────────────────────────────────────────
webhookMode      = input.string("live", "Webhook mode  ('live' requires executionMode='Live')", options=["disabled", "internal_paper", "projectx_sim", "live"], group=groupAlerts)
alertFormat      = input.string("JSON compact", "Alert message format", options=["JSON detailed", "JSON compact", "Plain text"], group=groupAlerts)
alertTag         = input.string("ABS_VWAP_V10", "Alert tag", group=groupAlerts)
brokerName       = input.string("projectx", "Broker name", group=groupAlerts)
brokerRootOverride = input.string("YM", "Broker root override", group=groupAlerts)
tvSymbolOverride = input.string("CBOT_MINI_DL:YM1!", "TV symbol override", group=groupAlerts)
paperQty         = input.int(1, "Quantity", minval=1, maxval=10, group=groupAlerts)
acceptLiveRisk   = input.bool(false, "I accept full live-trading risk  (must be true for executionMode=Live)", group=groupAlerts)

// ── Visuals ──────────────────────────────────────────────────────────────────
showVwap           = input.bool(true,  "Show VWAP", group=groupVisuals)
showSmallMarkers   = input.bool(true,  "Show small markers", group=groupVisuals)
showDebugTable     = input.bool(true,  "Show dashboard", group=groupVisuals)
debugTablePosition = input.string("Bottom right", "Dashboard position", options=["Top right", "Middle right", "Bottom right", "Top left", "Bottom left"], group=groupVisuals)
debugTableBgTransp = input.int(85, "Dashboard transparency", minval=0, maxval=100, group=groupVisuals)

// ── ENHANCEMENT A: HTF TREND FILTER ──────────────────────────────────────────
enableHtfFilter = input.bool(false, "Enable HTF trend filter", group=groupEnhanceHTF, tooltip="Only trade absorption signals that align with higher-timeframe trend. Reduces signals against strong trends.")
htfTimeframe    = input.string("60", "HTF timeframe (minutes)", group=groupEnhanceHTF)
htfTrendMethod  = input.string("EMA", "HTF trend method", options=["EMA", "VWAP"], group=groupEnhanceHTF)
htfEmaFast      = input.int(20, "HTF EMA fast", minval=5, group=groupEnhanceHTF)
htfEmaSlow      = input.int(50, "HTF EMA slow", minval=10, group=groupEnhanceHTF)
htfTrendThresh  = input.float(0.5, "HTF trend threshold (ATR multiple)", minval=0.1, step=0.1, group=groupEnhanceHTF, tooltip="How far HTF EMA/VWAP must be separated to qualify as 'strong trend'")

// ── ENHANCEMENT B: VOLATILITY REGIME FILTER ──────────────────────────────────
enableVolFilter    = input.bool(false, "Enable volatility regime filter", group=groupEnhanceVol, tooltip="Skip signals when volatility is too low (chop) or too high (event risk)")
volLookback        = input.int(100, "Vol percentile lookback", minval=20, group=groupEnhanceVol)
minVolPercentile   = input.float(25.0, "Min vol percentile", minval=0, maxval=100, step=5, group=groupEnhanceVol)
maxVolPercentile   = input.float(90.0, "Max vol percentile", minval=0, maxval=100, step=5, group=groupEnhanceVol)

// ── ENHANCEMENT C: TIME-DECAY EXIT ───────────────────────────────────────────
enableDecayExit = input.bool(false, "Enable time-decay exit", group=groupEnhanceDecay, tooltip="Tighten stop toward entry if trade hasn't moved toward target by mid-horizon")
decayStartBars  = input.int(5, "Decay start bars", minval=1, group=groupEnhanceDecay)
decayEndBars    = input.int(15, "Decay end bars (full tighten)", minval=2, group=groupEnhanceDecay)

// ── ENHANCEMENT D: TRAILING STOP ─────────────────────────────────────────────
enableTrailStop     = input.bool(false, "Enable trailing stop", group=groupEnhanceTrail, tooltip="Lock in winners by trailing stop once favorable excursion exceeds activation threshold")
trailActivationAtr  = input.float(0.5, "Trail activation (ATR)", minval=0.1, step=0.1, group=groupEnhanceTrail)
trailDistanceAtr    = input.float(1.0, "Trail distance (ATR)", minval=0.1, step=0.1, group=groupEnhanceTrail)

// ── ENHANCEMENT E: PARTIAL EXIT ──────────────────────────────────────────────
enablePartialExit = input.bool(false, "Enable partial exit (requires qty ≥2)", group=groupEnhancePartial, tooltip="Exit partial position at first target, hold runner to VWAP with breakeven stop")
tp1Fraction       = input.float(0.5, "TP1 fraction (0.5 = half position)", minval=0.1, maxval=0.9, step=0.1, group=groupEnhancePartial)
tp1AtrDistance    = input.float(0.5, "TP1 ATR distance", minval=0.1, step=0.1, group=groupEnhancePartial)

// ── ENHANCEMENT F: SIGNAL QUALITY SCORE ──────────────────────────────────────
enableScoreFilter = input.bool(false, "Enable signal quality score filter", group=groupEnhanceScore, tooltip="Only take signals scoring above threshold. Composite of volume/displacement/VWAP-distance/time-of-day")
minSignalScore    = input.float(60.0, "Min signal score (0-100)", minval=0, maxval=100, step=5, group=groupEnhanceScore)
scoreWeightVol    = input.float(0.3, "Score weight: volume excess", minval=0, maxval=1, step=0.1, group=groupEnhanceScore)
scoreWeightDisp   = input.float(0.3, "Score weight: displacement ratio", minval=0, maxval=1, step=0.1, group=groupEnhanceScore)
scoreWeightDist   = input.float(0.2, "Score weight: VWAP distance", minval=0, maxval=1, step=0.1, group=groupEnhanceScore)
scoreWeightTime   = input.float(0.2, "Score weight: time-of-day", minval=0, maxval=1, step=0.1, group=groupEnhanceScore)

// ── Helpers ──────────────────────────────────────────────────────────────────
f_volume_percentile(src, lookback) =>
    float count = 0.0
    float valid = 0.0
    for i = 0 to lookback - 1
        if not na(src[i])
            valid += 1.0
            if src[i] <= src
                count += 1.0
    valid > 0 ? 100.0 * count / valid : na

f_atr_percentile(lookback) =>
    atrNow = ta.atr(14)
    float count = 0.0
    float valid = 0.0
    for i = 0 to lookback - 1
        atrPast = ta.atr(14)[i]
        if not na(atrPast)
            valid += 1.0
            if atrPast <= atrNow
                count += 1.0
    valid > 0 ? 100.0 * count / valid : na

f_num(x) => na(x) ? "null" : str.tostring(x, "#.#####")
f_bool(x) => x ? "true" : "false"
f_fmt(x, fmt) => na(x) ? "n/a" : str.tostring(x, fmt)
f_table_pos(t) => t == "Top right" ? position.top_right : t == "Middle right" ? position.middle_right : t == "Bottom right" ? position.bottom_right : t == "Top left" ? position.top_left : position.bottom_left

// ── Execution gates ──────────────────────────────────────────────────────────
liveAuthorized = executionMode == "Live" and webhookMode == "live" and acceptLiveRisk
liveAllowedJson = liveAuthorized
simAllowedJson  = executionMode == "Sim/Paper" or executionMode == "Live"

// ── Session / time ───────────────────────────────────────────────────────────
inRth = not na(time(timeframe.period, rthSession, rthTimezone))
rthSessionStart = inRth and not inRth[1]
dailySessionStart = timeframe.change("D")
newSession = useRthOnly ? rthSessionStart : dailySessionStart
vwapActiveBar = useRthOnly ? inRth : true

nyHour   = hour(time, rthTimezone)
nyMinute = minute(time, rthTimezone)
nyMin    = nyHour * 60 + nyMinute
middayStart   = middayStartHour * 60 + middayStartMin
middayEnd     = middayEndHour   * 60 + middayEndMin
entryCutoff   = entryCutoffHour * 60 + entryCutoffMin
eodFlattenMin = eodFlattenHour  * 60 + eodFlattenMinute

nyDow = dayofweek(time, rthTimezone)
allowedDayPass = allowedDays == "Mon-Fri" ? (nyDow >= dayofweek.monday and nyDow <= dayofweek.friday) : allowedDays == "Mon-Thu" ? (nyDow >= dayofweek.monday and nyDow <= dayofweek.thursday) : (nyDow >= dayofweek.tuesday and nyDow <= dayofweek.thursday)

inMiddayBlock   = useSessionFilter and blockMidday and nyMin >= middayStart and nyMin < middayEnd
inHour11Block   = useSessionFilter and blockHour11 and nyHour == 11
pastEntryCutoff = useSessionFilter and useEntryCutoff and nyMin >= entryCutoff
sessionFilterPass = not useSessionFilter or (allowedDayPass and not inMiddayBlock and not inHour11Block and not pastEntryCutoff)

inEodWindow = useEodFlatten and inRth and nyMin >= eodFlattenMin
eodFlattenTrigger = inEodWindow and not inEodWindow[1]
nearEodFlatten = inEodWindow

// ── VWAP ─────────────────────────────────────────────────────────────────────
var float cumPV = na
var float cumVol = na
typicalPrice = (high + low + close) / 3.0
if newSession or na(cumPV) or na(cumVol)
    cumPV := vwapActiveBar ? typicalPrice * volume : na
    cumVol := vwapActiveBar ? volume : na
else if vwapActiveBar
    cumPV += typicalPrice * volume
    cumVol += volume
sessionVwap = vwapActiveBar and cumVol > 0 ? cumPV / cumVol : na

// ── Preset effective values ──────────────────────────────────────────────────
isPresetV9      = presetMode == "ES V9 Balanced"
isPresetES      = presetMode == "ES Paper Candidate"
isPresetManual  = presetMode == "Manual"
isPresetDefault = presetMode == "Default setup"
isPresetCand1   = presetMode == "Candidate 1: VL75 / VP97.5 / ATR60 / Disp0.5 / Near0.5 / H20"
isPresetCand4   = presetMode == "Candidate 4: VL100 / VP97.5 / ATR60 / Disp0.2 / Near0.1 / H10"
isPresetCand8   = presetMode == "Candidate 8: VL100 / VP97.5 / ATR20 / Disp0.3 / Near0.25 / H5"

effVolumeLookback                = isPresetV9 or isPresetES ? 50 : isPresetCand1 ? 75 : isPresetManual ? manualVolumeLookback : 100
effHighVolumePercentileThreshold = isPresetV9 or isPresetES ? 90.0 : isPresetManual ? manualHighVolumePercentileThreshold : isPresetDefault ? 95.0 : 97.5
effAtrLength                     = isPresetV9 or isPresetES ? 80 : isPresetCand8 ? 20 : isPresetManual ? manualAtrLength : 60
effMaxDisplacementAtr            = isPresetV9 or isPresetES ? 0.30 : isPresetCand1 ? 0.50 : isPresetCand4 ? 0.20 : isPresetManual ? manualMaxDisplacementAtr : 0.30
effNearVwapThresholdAtr          = isPresetV9 or isPresetES ? 0.25 : isPresetCand1 ? 0.50 : isPresetCand4 ? 0.10 : isPresetManual ? manualNearVwapThresholdAtr : 0.25
effReversalHorizonBars           = isPresetV9 or isPresetES ? 15 : isPresetCand1 ? 20 : isPresetCand4 ? 10 : isPresetCand8 ? 5 : isPresetManual ? manualReversalHorizonBars : 15

atr20 = ta.atr(20)
atr60 = ta.atr(60)
atr80 = ta.atr(80)
manualAtr = ta.atr(manualAtrLength)
atr = isPresetV9 or isPresetES ? atr80 : isPresetCand8 ? atr20 : isPresetManual ? manualAtr : atr60

volPct50  = f_volume_percentile(volume, 50)
volPct75  = f_volume_percentile(volume, 75)
volPct100 = f_volume_percentile(volume, 100)
manualVolumePercentile = f_volume_percentile(volume, manualVolumeLookback)
volumePercentile = isPresetV9 or isPresetES ? volPct50 : isPresetCand1 ? volPct75 : isPresetManual ? manualVolumePercentile : volPct100

bodyDisplacement = math.abs(close - open)
displacementAtr  = atr > 0 ? bodyDisplacement / atr : na
vwapDistanceAtr  = atr > 0 and not na(sessionVwap) ? (close - sessionVwap) / atr : na
nearVwap         = not na(vwapDistanceAtr) and math.abs(vwapDistanceAtr) <= effNearVwapThresholdAtr
aboveVwap        = not nearVwap and not na(sessionVwap) and close > sessionVwap
belowVwap        = not nearVwap and not na(sessionVwap) and close < sessionVwap
locationLabel    = nearVwap ? "near_vwap" : aboveVwap ? "above_vwap" : belowVwap ? "below_vwap" : "unknown"

validForSignal      = enableAbsorptionModule and barstate.isconfirmed and vwapActiveBar and not na(sessionVwap) and not na(atr) and not na(volumePercentile)
highVolumePass      = validForSignal and volumePercentile >= effHighVolumePercentileThreshold
lowDisplacementPass = validForSignal and displacementAtr <= effMaxDisplacementAtr
isAbsorptionBar     = validForSignal and highVolumePass and lowDisplacementPass

absorptionWarning      = isAbsorptionBar
aboveVwapAbsorption    = absorptionWarning and aboveVwap
belowVwapAbsorption    = absorptionWarning and belowVwap
nearVwapAbsorption     = absorptionWarning and nearVwap
vwapReversionCandidate = aboveVwapAbsorption or belowVwapAbsorption

directionAllowsShort  = paperDirectionMode != "Longs only"
directionAllowsLong   = paperDirectionMode != "Shorts only"
rawShortCandidate     = aboveVwapAbsorption and allowFadeAboveVwap and directionAllowsShort
rawLongCandidate      = belowVwapAbsorption and allowFadeBelowVwap and directionAllowsLong
sideSessionBlockShort = useSessionFilter and ((blockShortsHour14 and nyHour == 14) or (blockFridayShorts and nyDow == dayofweek.friday))
sideSessionBlockLong  = useSessionFilter and blockLongsHour12 and nyHour == 12

// ── ENHANCEMENT A: HTF TREND FILTER APPLICATION ──────────────────────────────
htfTrendBias = 0
htfTrendStrength = 0.0
if enableHtfFilter
    [htfVwap, htfEmaF, htfEmaS] = request.security(syminfo.tickerid, htfTimeframe, [sessionVwap, ta.ema(close, htfEmaFast), ta.ema(close, htfEmaSlow)], lookahead=barmerge.lookahead_off)
    htfAtr = request.security(syminfo.tickerid, htfTimeframe, atr, lookahead=barmerge.lookahead_off)
    if htfTrendMethod == "EMA" and not na(htfEmaF) and not na(htfEmaS) and not na(htfAtr) and htfAtr > 0
        htfSeparation = (htfEmaF - htfEmaS) / htfAtr
        htfTrendStrength := htfSeparation
        if htfSeparation > htfTrendThresh
            htfTrendBias := 1  // uptrend
        else if htfSeparation < -htfTrendThresh
            htfTrendBias := -1 // downtrend
        else
            htfTrendBias := 0  // neutral
    else if htfTrendMethod == "VWAP" and not na(htfVwap) and not na(close) and not na(htfAtr) and htfAtr > 0
        htfVwapDist = (close - htfVwap) / htfAtr
        htfTrendStrength := htfVwapDist
        if htfVwapDist > htfTrendThresh
            htfTrendBias := 1
        else if htfVwapDist < -htfTrendThresh
            htfTrendBias := -1
        else
            htfTrendBias := 0

htfFilterPass = not enableHtfFilter or (htfTrendBias == 0) or (rawShortCandidate and htfTrendBias != 1) or (rawLongCandidate and htfTrendBias != -1)

// ── ENHANCEMENT B: VOLATILITY REGIME FILTER APPLICATION ──────────────────────
atrPercentile = enableVolFilter ? f_atr_percentile(volLookback) : 50.0
volFilterPass = not enableVolFilter or (not na(atrPercentile) and atrPercentile >= minVolPercentile and atrPercentile <= maxVolPercentile)

// ── ENHANCEMENT F: SIGNAL QUALITY SCORE ──────────────────────────────────────
signalScore = 0.0
if enableScoreFilter and isAbsorptionBar
    // Volume score: excess above threshold (0-100 scale)
    volExcess = volumePercentile - effHighVolumePercentileThreshold
    volScore = math.min(100.0, volExcess * 10.0)
    
    // Displacement score: lower is better (inverse scale)
    dispScore = displacementAtr <= 0.1 ? 100.0 : displacementAtr <= 0.3 ? 75.0 : displacementAtr <= 0.5 ? 50.0 : 25.0
    
    // VWAP distance score: further from VWAP = better mean reversion setup
    vwapDistScore = not na(vwapDistanceAtr) ? math.min(100.0, math.abs(vwapDistanceAtr) * 100.0) : 0.0
    
    // Time-of-day score: best hours score higher (9:30-10:30, 13:30-15:30 are typical strong windows)
    timeScore = (nyHour == 9 and nyMinute >= 30) or nyHour == 10 ? 100.0 : (nyHour >= 13 and nyHour <= 15) ? 80.0 : 50.0
    
    // Weighted composite
    signalScore := volScore * scoreWeightVol + dispScore * scoreWeightDisp + vwapDistScore * scoreWeightDist + timeScore * scoreWeightTime

scoreFilterPass = not enableScoreFilter or signalScore >= minSignalScore

// Apply all enhancement filters
shortCandidate = rawShortCandidate and not sideSessionBlockShort and htfFilterPass and volFilterPass and scoreFilterPass
longCandidate  = rawLongCandidate  and not sideSessionBlockLong  and htfFilterPass and volFilterPass and scoreFilterPass

// ── Risk state ───────────────────────────────────────────────────────────────
var int    tradesToday          = 0
var float  dayPnl               = 0.0
var int    dayConsecLosses      = 0
var bool   dayHalted            = false
var string dayHaltReason        = "NONE"
var int    previousClosedTrades = 0
var int    sameBarExitCount     = 0
var float  peakNetProfit        = 0.0

if newSession
    tradesToday := 0
    dayPnl := 0.0
    dayConsecLosses := 0
    dayHalted := false
    dayHaltReason := "NONE"

if strategy.closedtrades > previousClosedTrades
    for tradeIndex = previousClosedTrades to strategy.closedtrades - 1
        p = strategy.closedtrades.profit(tradeIndex)
        dayPnl += p
        dayConsecLosses := p > 0 ? 0 : dayConsecLosses + 1
        entryIdx = strategy.closedtrades.entry_bar_index(tradeIndex)
        exitIdx  = strategy.closedtrades.exit_bar_index(tradeIndex)
        if entryIdx == exitIdx
            sameBarExitCount += 1
    previousClosedTrades := strategy.closedtrades

peakNetProfit := math.max(peakNetProfit, strategy.netprofit)
drawdownFromPeak = strategy.netprofit - peakNetProfit

accountLossHard    = useAccountLossKill and strategy.netprofit <= -maxAccountLossDollar
peakDdHard         = usePeakDdKill and drawdownFromPeak <= -maxPeakDrawdownDollar
dailyLossHard      = useDailyLossStop and dayPnl <= -dailyLossStopDollar
dailyProfitLockHit = useDailyProfitLock and dayPnl >= dailyProfitLockDollar
consecLossHit      = useConsecLossKill and dayConsecLosses >= consecLossLimit
cushionLocked      = useCushionLock and strategy.netprofit < cushionLockTarget
riskHaltNow        = accountLossHard or peakDdHard or dailyLossHard or dailyProfitLockHit or consecLossHit

if riskHaltNow and not dayHalted
    dayHalted := true
    dayHaltReason := accountLossHard ? "ACCOUNT_LOSS_KILL" : peakDdHard ? "PEAK_DD_KILL" : dailyLossHard ? "DAILY_LOSS_STOP" : dailyProfitLockHit ? "DAILY_PROFIT_LOCK" : "CONSEC_LOSS_KILL"

riskState = accountLossHard or peakDdHard ? "DISABLED_HARD" : dayHalted ? "DISABLED_DAY" : cushionLocked ? "CUSHION_LOCK" : useDailyLossStop and dayPnl <= -dailyLossStopDollar * 0.5 ? "CAUTION" : "NORMAL"

blockReasonSignal = not enableAbsorptionModule ? "MODULE_DISABLED" : not vwapActiveBar ? "OUTSIDE_RTH" : na(sessionVwap) ? "VWAP_UNAVAILABLE" : na(atr) ? "ATR_UNAVAILABLE" : na(volumePercentile) ? "VOLUME_LOOKBACK_UNAVAILABLE" : not htfFilterPass ? "HTF_FILTER_BLOCK" : not volFilterPass ? "VOL_REGIME_BLOCK" : not scoreFilterPass ? "SCORE_FILTER_BLOCK" : isAbsorptionBar ? "PASS" : not highVolumePass ? "HIGH_VOLUME_FAIL" : not lowDisplacementPass ? "DISPLACEMENT_FAIL" : "NOT_ABSORPTION"

tradeBlockReason = strategy.position_size != 0 ? "POSITION_OPEN" : not sessionFilterPass ? "SESSION_BLOCK" : nearEodFlatten ? "EOD_FLATTEN_WINDOW" : dayHalted ? dayHaltReason : cushionLocked ? "CUSHION_LOCK" : tradesToday >= maxTradesPerDay ? "MAX_TRADES_DAY" : "NONE"

// ── Alert message builder ────────────────────────────────────────────────────
f_alert_json_detailed(eventName, side, action, reason) =>
    key = syminfo.ticker + "_" + str.tostring(time) + "_" + eventName + "_" + side
    string s = "{"
    s += "\"schema\":\"ABS_VWAP_V10\","
    s += "\"tag\":\"" + alertTag + "\","
    s += "\"event\":\"" + eventName + "\","
    s += "\"action\":\"" + action + "\","
    s += "\"side\":\"" + side + "\","
    s += "\"qty\":" + str.tostring(paperQty) + ","
    s += "\"symbol\":\"" + tvSymbolOverride + "\","
    s += "\"ticker\":\"" + syminfo.ticker + "\","
    s += "\"broker_root\":\"" + brokerRootOverride + "\","
    s += "\"broker\":\"" + brokerName + "\","
    s += "\"order_type\":\"market\","
    s += "\"price\":" + f_num(close) + ","
    s += "\"vwap\":" + f_num(sessionVwap) + ","
    s += "\"timeframe\":\"" + timeframe.period + "\","
    s += "\"bar_time\":" + str.tostring(time) + ","
    s += "\"idempotency_key\":\"" + key + "\","
    s += "\"webhook_mode\":\"" + webhookMode + "\","
    s += "\"execution_mode\":\"" + executionMode + "\","
    s += "\"execution_allowed\":" + f_bool(liveAuthorized or simAllowedJson) + ","
    s += "\"live_allowed\":" + f_bool(liveAllowedJson) + ","
    s += "\"sim_only\":" + f_bool(not liveAllowedJson) + ","
    s += "\"risk_state\":\"" + riskState + "\","
    s += "\"block_reason\":\"" + tradeBlockReason + "\","
    s += "\"reason\":\"" + reason + "\""
    s += "}"
    s

f_alert_json_compact(eventName, side, action) =>
    key = syminfo.ticker + "_" + str.tostring(time) + "_" + eventName + "_" + side
    string s = "{"
    s += "\"action\":\"" + action + "\","
    s += "\"side\":\"" + side + "\","
    s += "\"qty\":" + str.tostring(paperQty) + ","
    s += "\"symbol\":\"" + tvSymbolOverride + "\","
    s += "\"broker_root\":\"" + brokerRootOverride + "\","
    s += "\"price\":" + f_num(close) + ","
    s += "\"key\":\"" + key + "\","
    s += "\"live\":" + f_bool(liveAllowedJson)
    s += "}"
    s

f_alert_plain(eventName, side, action) =>
    key = syminfo.ticker + "_" + str.tostring(time) + "_" + eventName + "_" + side
    action + "|" + side + "|" + str.tostring(paperQty) + "|" + tvSymbolOverride + "|" + brokerRootOverride + "|" + f_num(close) + "|" + key + "|live=" + f_bool(liveAllowedJson)

f_alert(eventName, side, action, reason) =>
    alertFormat == "JSON detailed" ? f_alert_json_detailed(eventName, side, action, reason) : alertFormat == "JSON compact" ? f_alert_json_compact(eventName, side, action) : f_alert_plain(eventName, side, action)

// ── Plots / markers ──────────────────────────────────────────────────────────
plot(showVwap ? sessionVwap : na, "Session VWAP", color=color.new(color.blue, 0), linewidth=2)
plotshape(showSmallMarkers and aboveVwapAbsorption, title="Above VWAP absorption", style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0), size=size.tiny, text="ABS↓")
plotshape(showSmallMarkers and belowVwapAbsorption, title="Below VWAP absorption", style=shape.triangleup,   location=location.belowbar, color=color.new(color.lime, 0), size=size.tiny, text="ABS↑")
plotshape(showSmallMarkers and nearVwapAbsorption,  title="Near VWAP absorption",  style=shape.diamond,       location=location.top,      color=color.new(color.gray, 0), size=size.tiny, text="ABS")

blockedDirectionalSignal = (rawShortCandidate or rawLongCandidate) and not (shortCandidate or longCandidate)
plotshape(showSmallMarkers and blockedDirectionalSignal, title="Blocked by filter", style=shape.xcross, location=location.abovebar, color=color.new(color.orange, 0), size=size.tiny, text="BLK")

// ── Trading engine ───────────────────────────────────────────────────────────
var int   pendingDir       = 0
var int   pendingSignalBar = na
var float pendingStop      = na
var float pendingLimit     = na
var float activeStop       = na
var float activeLimit      = na
var int   positionEntryBar = na
var float entryAtr         = na
var bool  tp1Fired         = false

if strategy.position_size != 0 and strategy.position_size[1] == 0
    positionEntryBar := bar_index
    entryAtr := atr
    tp1Fired := false

if strategy.position_size == 0 and strategy.position_size[1] != 0
    positionEntryBar := na
    activeStop := na
    activeLimit := na
    entryAtr := na
    tp1Fired := false

orderExecutionOk = (executionMode == "Sim/Paper" or executionMode == "Live") and enablePaperStrategy

hardRiskRequiresClose = forceCloseOnHardRisk and (accountLossHard or peakDdHard) and strategy.position_size != 0
if orderExecutionOk and hardRiskRequiresClose
    hardSide   = strategy.position_size > 0 ? "long" : "short"
    hardAction = strategy.position_size > 0 ? "CLOSE_LONG" : "CLOSE_SHORT"
    strategy.close_all(comment="RISK", alert_message=f_alert("hard_risk_flatten", hardSide, hardAction, dayHaltReason))

if orderExecutionOk and useEodFlatten and eodFlattenTrigger and strategy.position_size != 0
    eodSide   = strategy.position_size > 0 ? "long" : "short"
    eodAction = strategy.position_size > 0 ? "CLOSE_LONG" : "CLOSE_SHORT"
    strategy.close_all(comment="EOD", alert_message=f_alert("eod_flatten", eodSide, eodAction, "eod_flatten_window"))

hardDollarTriggered = false
if useHardDollarStop and strategy.position_size != 0 and not na(strategy.position_avg_price)
    pv = syminfo.pointvalue
    if strategy.position_size > 0
        unrealized_per_ct = (close - strategy.position_avg_price) * pv
        hardDollarTriggered := unrealized_per_ct <= -hardDollarStopAmount
    else
        unrealized_per_ct = (strategy.position_avg_price - close) * pv
        hardDollarTriggered := unrealized_per_ct <= -hardDollarStopAmount
if orderExecutionOk and useHardDollarStop and hardDollarTriggered and strategy.position_size != 0
    hsSide   = strategy.position_size > 0 ? "long" : "short"
    hsAction = strategy.position_size > 0 ? "CLOSE_LONG" : "CLOSE_SHORT"
    strategy.close_all(comment="HS", alert_message=f_alert("hard_dollar_stop", hsSide, hsAction, "per_trade_dollar_stop_hit"))

canTradeNow = orderExecutionOk and vwapActiveBar and sessionFilterPass and not nearEodFlatten and not dayHalted and not cushionLocked and tradesToday < maxTradesPerDay and strategy.position_size == 0

if canTradeNow and (shortCandidate or longCandidate)
    sigDir = shortCandidate ? -1 : 1
    sigSide = sigDir == -1 ? "short" : "long"
    sigStop = shortCandidate ? high + atr * stopAtrMultiple : low - atr * stopAtrMultiple
    sigLimit = sessionVwap
    if nextBarEntryOnly
        pendingDir := sigDir
        pendingSignalBar := bar_index
        pendingStop := sigStop
        pendingLimit := sigLimit
    else
        activeStop := sigStop
        activeLimit := sigLimit
        entryMsg = f_alert("entry", sigSide, sigDir == -1 ? "SELL_SHORT" : "BUY", "same_bar_entry")
        if sigDir == -1
            strategy.entry("ABS_S", strategy.short, qty=paperQty, comment="S", alert_message=entryMsg)
        else
            strategy.entry("ABS_L", strategy.long, qty=paperQty, comment="L", alert_message=entryMsg)
        tradesToday += 1

pendingExpired = pendingDir != 0 and not na(pendingSignalBar) and bar_index - pendingSignalBar > pendingEntryMaxBars
if pendingExpired or not vwapActiveBar or dayHalted or not sessionFilterPass or nearEodFlatten or cushionLocked
    pendingDir := 0
    pendingSignalBar := na
    pendingStop := na
    pendingLimit := na

if nextBarEntryOnly and canTradeNow and pendingDir != 0 and not na(pendingSignalBar) and bar_index > pendingSignalBar and bar_index - pendingSignalBar <= pendingEntryMaxBars
    activeStop := pendingStop
    activeLimit := pendingLimit
    pendingSide = pendingDir == -1 ? "short" : "long"
    entryMsg = f_alert("entry", pendingSide, pendingDir == -1 ? "SELL_SHORT" : "BUY", "next_bar_entry")
    if pendingDir == -1
        strategy.entry("ABS_S", strategy.short, qty=paperQty, comment="S", alert_message=entryMsg)
    else
        strategy.entry("ABS_L", strategy.long, qty=paperQty, comment="L", alert_message=entryMsg)
    tradesToday += 1
    pendingDir := 0
    pendingSignalBar := na
    pendingStop := na
    pendingLimit := na

// ── ENHANCEMENT E: PARTIAL EXIT APPLICATION ──────────────────────────────────
if orderExecutionOk and enablePartialExit and strategy.position_size != 0 and not na(positionEntryBar) and not na(entryAtr) and not tp1Fired and paperQty >= 2
    barsInTrade = bar_index - positionEntryBar
    if barsInTrade > 0
        tp1Qty = math.floor(paperQty * tp1Fraction)
        tp1Distance = tp1AtrDistance * entryAtr
        if strategy.position_size > 0
            tp1Price = strategy.position_avg_price + tp1Distance
            if high >= tp1Price
                strategy.close("ABS_L", qty=tp1Qty, comment="TP1", alert_message=f_alert("partial_exit", "long", "CLOSE_LONG_PARTIAL", "tp1_hit"))
                tp1Fired := true
        else if strategy.position_size < 0
            tp1Price = strategy.position_avg_price - tp1Distance
            if low <= tp1Price
                strategy.close("ABS_S", qty=tp1Qty, comment="TP1", alert_message=f_alert("partial_exit", "short", "CLOSE_SHORT_PARTIAL", "tp1_hit"))
                tp1Fired := true

// ── ENHANCEMENT D: TRAILING STOP APPLICATION ─────────────────────────────────
var float trailStopPrice = na
if enableTrailStop and strategy.position_size != 0 and not na(positionEntryBar) and not na(entryAtr)
    activationDist = trailActivationAtr * entryAtr
    trailDist = trailDistanceAtr * entryAtr
    if strategy.position_size > 0
        favorableMove = high - strategy.position_avg_price
        if favorableMove >= activationDist
            newTrailStop = high - trailDist
            trailStopPrice := na(trailStopPrice) ? newTrailStop : math.max(trailStopPrice, newTrailStop)
    else if strategy.position_size < 0
        favorableMove = strategy.position_avg_price - low
        if favorableMove >= activationDist
            newTrailStop = low + trailDist
            trailStopPrice := na(trailStopPrice) ? newTrailStop : math.min(trailStopPrice, newTrailStop)

if strategy.position_size == 0
    trailStopPrice := na

// ── ENHANCEMENT C: TIME-DECAY EXIT APPLICATION ───────────────────────────────
var float decayStop = na
if enableDecayExit and strategy.position_size != 0 and not na(positionEntryBar) and not na(activeStop) and not na(activeLimit) and not na(strategy.position_avg_price)
    barsInTrade = bar_index - positionEntryBar
    if barsInTrade >= decayStartBars
        progressToTarget = 0.0
        if strategy.position_size > 0
            totalDistance = activeLimit - strategy.position_avg_price
            currentDistance = close - strategy.position_avg_price
            progressToTarget := totalDistance > 0 ? currentDistance / totalDistance : 0.0
        else if strategy.position_size < 0
            totalDistance = strategy.position_avg_price - activeLimit
            currentDistance = strategy.position_avg_price - close
            progressToTarget := totalDistance > 0 ? currentDistance / totalDistance : 0.0
        
        if progressToTarget < 0.3
            decayFraction = (barsInTrade - decayStartBars) / (decayEndBars - decayStartBars)
            decayFraction := math.min(1.0, math.max(0.0, decayFraction))
            originalStopDist = math.abs(activeStop - strategy.position_avg_price)
            newStopDist = originalStopDist * (1.0 - decayFraction * 0.7)
            if strategy.position_size > 0
                decayStop := strategy.position_avg_price - newStopDist
            else
                decayStop := strategy.position_avg_price + newStopDist

if strategy.position_size == 0
    decayStop := na

exitEligible = strategy.position_size != 0 and not na(positionEntryBar) and (allowSameBarExit or bar_index > positionEntryBar)
useStopExit  = exitMode == "VWAP target + ATR stop + time stop" or exitMode == "ATR stop only"
useLimitExit = exitMode == "VWAP target + ATR stop + time stop" or exitMode == "VWAP target only"
useTimeStop  = exitMode == "VWAP target + ATR stop + time stop" or exitMode == "Fixed horizon only"

// Determine effective stop (consider enhancements)
effectiveStop = na(float)
if not na(activeStop)
    effectiveStop := activeStop
if enableDecayExit and not na(decayStop)
    if strategy.position_size > 0
        effectiveStop := na(effectiveStop) ? decayStop : math.max(effectiveStop, decayStop)
    else
        effectiveStop := na(effectiveStop) ? decayStop : math.min(effectiveStop, decayStop)
if enableTrailStop and not na(trailStopPrice)
    if strategy.position_size > 0
        effectiveStop := na(effectiveStop) ? trailStopPrice : math.max(effectiveStop, trailStopPrice)
    else
        effectiveStop := na(effectiveStop) ? trailStopPrice : math.min(effectiveStop, trailStopPrice)

if orderExecutionOk and exitEligible and (useStopExit or useLimitExit)
    if strategy.position_size > 0
        exitMsg = f_alert("exit", "long", "CLOSE_LONG", exitMode)
        strategy.exit("ABS_L_X", "ABS_L", stop = useStopExit and not na(effectiveStop) ? effectiveStop : na, limit = useLimitExit and not na(activeLimit) ? activeLimit : na, comment="XL", alert_message=exitMsg)
    if strategy.position_size < 0
        exitMsg = f_alert("exit", "short", "CLOSE_SHORT", exitMode)
        strategy.exit("ABS_S_X", "ABS_S", stop = useStopExit and not na(effectiveStop) ? effectiveStop : na, limit = useLimitExit and not na(activeLimit) ? activeLimit : na, comment="XS", alert_message=exitMsg)

if orderExecutionOk and useTimeStop and strategy.position_size != 0 and not na(positionEntryBar) and bar_index - positionEntryBar >= effReversalHorizonBars
    closeSide = strategy.position_size > 0 ? "long" : "short"
    strategy.close_all(comment="T", alert_message=f_alert("time_stop", closeSide, closeSide == "long" ? "CLOSE_LONG" : "CLOSE_SHORT", "horizon_reached"))

// ── Dashboard ────────────────────────────────────────────────────────────────
cellBg   = color.new(color.black, debugTableBgTransp)
headerBg = color.new(color.gray, math.max(debugTableBgTransp - 10, 0))
var table dash = table.new(f_table_pos(debugTablePosition), 4, 16, border_width=1)
if showDebugTable and barstate.islast
    table.cell(dash, 0, 0, "V10", bgcolor=headerBg, text_color=color.white, text_size=size.tiny)
    table.cell(dash, 1, 0, "Value", bgcolor=headerBg, text_color=color.white, text_size=size.tiny)
    table.cell(dash, 2, 0, "Detail", bgcolor=headerBg, text_color=color.white, text_size=size.tiny)
    table.cell(dash, 3, 0, "Notes", bgcolor=headerBg, text_color=color.white, text_size=size.tiny)

    table.cell(dash, 0, 1, "Exec mode")
    table.cell(dash, 1, 1, executionMode, text_color=liveAuthorized ? color.red : color.white)
    table.cell(dash, 2, 1, webhookMode)
    table.cell(dash, 3, 1, liveAuthorized ? "LIVE AUTH" : "sim/paper")

    table.cell(dash, 0, 2, "Preset / fmt")
    table.cell(dash, 1, 2, presetMode)
    table.cell(dash, 2, 2, alertFormat)
    table.cell(dash, 3, 2, alertTag)

    table.cell(dash, 0, 3, "Session")
    table.cell(dash, 1, 3, sessionFilterPass ? "PASS" : "BLOCK")
    table.cell(dash, 2, 3, tradeBlockReason)
    table.cell(dash, 3, 3, blockMidday ? "10-13 blocked" : (blockHour11 ? "11am blocked" : "no blocks"))

    table.cell(dash, 0, 4, "Day PnL")
    table.cell(dash, 1, 4, str.tostring(dayPnl, "#.##"))
    table.cell(dash, 2, 4, "Trades " + str.tostring(tradesToday) + "/" + str.tostring(maxTradesPerDay))
    table.cell(dash, 3, 4, "Consec L " + str.tostring(dayConsecLosses))

    table.cell(dash, 0, 5, "Net/DD")
    table.cell(dash, 1, 5, str.tostring(strategy.netprofit, "#.##"))
    table.cell(dash, 2, 5, str.tostring(drawdownFromPeak, "#.##"))
    table.cell(dash, 3, 5, dayHaltReason)

    table.cell(dash, 0, 6, "Risk state")
    table.cell(dash, 1, 6, riskState)
    table.cell(dash, 2, 6, useDailyLossStop ? "DLS$" + str.tostring(dailyLossStopDollar) : "no DLS")
    table.cell(dash, 3, 6, useHardDollarStop ? "HS$" + str.tostring(hardDollarStopAmount) : "no HS")

    table.cell(dash, 0, 7, "Vol/Disp")
    table.cell(dash, 1, 7, f_fmt(volumePercentile, "#.##"))
    table.cell(dash, 2, 7, f_fmt(displacementAtr, "#.####"))
    table.cell(dash, 3, 7, blockReasonSignal)

    table.cell(dash, 0, 8, "Location")
    table.cell(dash, 1, 8, locationLabel)
    table.cell(dash, 2, 8, f_fmt(vwapDistanceAtr, "#.####"))
    table.cell(dash, 3, 8, vwapActiveBar ? "RTH" : "outside")

    table.cell(dash, 0, 9, "Candidate")
    table.cell(dash, 1, 9, shortCandidate ? "SHORT" : longCandidate ? "LONG" : blockedDirectionalSignal ? "BLOCKED" : "none")
    table.cell(dash, 2, 9, canTradeNow ? "can trade" : "blocked")
    table.cell(dash, 3, 9, tradeBlockReason)

    table.cell(dash, 0, 10, "Webhook")
    table.cell(dash, 1, 10, webhookMode)
    table.cell(dash, 2, 10, brokerRootOverride + " qty " + str.tostring(paperQty))
    table.cell(dash, 3, 10, alertFormat)

    table.cell(dash, 0, 11, "Fill audit")
    table.cell(dash, 1, 11, "nextBar " + f_bool(nextBarEntryOnly))
    table.cell(dash, 2, 11, "sameExit " + f_bool(allowSameBarExit))
    table.cell(dash, 3, 11, "same " + str.tostring(sameBarExitCount))

    // ENHANCEMENT G: Display enhancement telemetry
    table.cell(dash, 0, 12, "HTF Trend")
    htfLabel = htfTrendBias == 1 ? "UP" : htfTrendBias == -1 ? "DOWN" : "NEUTRAL"
    table.cell(dash, 1, 12, enableHtfFilter ? htfLabel : "OFF", text_color=enableHtfFilter ? (htfTrendBias == 0 ? color.white : color.yellow) : color.gray)
    table.cell(dash, 2, 12, enableHtfFilter ? f_fmt(htfTrendStrength, "#.##") : "-")
    table.cell(dash, 3, 12, enableHtfFilter ? htfTimeframe + "m " + htfTrendMethod : "disabled")

    table.cell(dash, 0, 13, "Vol Regime")
    table.cell(dash, 1, 13, enableVolFilter ? f_fmt(atrPercentile, "#.#") : "OFF", text_color=enableVolFilter ? (volFilterPass ? color.lime : color.red) : color.gray)
    table.cell(dash, 2, 13, enableVolFilter ? str.tostring(minVolPercentile, "#") + "-" + str.tostring(maxVolPercentile, "#") : "-")
    table.cell(dash, 3, 13, enableVolFilter ? (volFilterPass ? "PASS" : "BLOCK") : "disabled")

    table.cell(dash, 0, 14, "Signal Score")
    table.cell(dash, 1, 14, enableScoreFilter ? f_fmt(signalScore, "#.#") : "OFF", text_color=enableScoreFilter ? (scoreFilterPass ? color.lime : color.red) : color.gray)
    table.cell(dash, 2, 14, enableScoreFilter ? "min " + str.tostring(minSignalScore, "#") : "-")
    table.cell(dash, 3, 14, enableScoreFilter ? (scoreFilterPass ? "PASS" : "BLOCK") : "disabled")

    table.cell(dash, 0, 15, "Enhancements")
    enhList = (enableHtfFilter ? "HTF " : "") + (enableVolFilter ? "VOL " : "") + (enableDecayExit ? "DECAY " : "") + (enableTrailStop ? "TRAIL " : "") + (enablePartialExit ? "PART " : "") + (enableScoreFilter ? "SCORE" : "")
    table.cell(dash, 1, 15, enhList == "" ? "NONE (V9.1 baseline)" : enhList, text_color=enhList == "" ? color.gray : color.cyan)
    table.cell(dash, 2, 15, strategy.position_size != 0 and not na(effectiveStop) ? "Stop: " + f_fmt(effectiveStop, "#.##") : "-")
    table.cell(dash, 3, 15, tp1Fired ? "TP1 fired" : "")
